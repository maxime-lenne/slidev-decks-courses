{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://simplon.co/schemas/slidev/index-data.json",
  "title": "IndexData",
  "description": "Consolidated catalog of all published slide decks, generated at build time",
  "type": "object",
  "required": ["generated", "version", "decks", "stats"],
  "properties": {
    "generated": {
      "type": "string",
      "description": "ISO 8601 timestamp when this index was generated",
      "format": "date-time",
      "examples": ["2025-11-24T10:30:00Z", "2024-03-15T14:22:33.123Z"]
    },
    "version": {
      "type": "string",
      "description": "Index data schema version",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "examples": ["1.0.0", "2.1.0"]
    },
    "decks": {
      "type": "array",
      "description": "Array of all published deck metadata",
      "items": {
        "$ref": "deck-metadata.schema.json"
      },
      "minItems": 0
    },
    "stats": {
      "type": "object",
      "description": "Aggregate statistics across all decks",
      "required": ["totalDecks", "totalDuration", "languages", "themes", "tags"],
      "properties": {
        "totalDecks": {
          "type": "integer",
          "description": "Total number of published decks",
          "minimum": 0,
          "examples": [5, 12, 0]
        },
        "totalDuration": {
          "type": "integer",
          "description": "Sum of all deck durations in minutes",
          "minimum": 0,
          "examples": [240, 450]
        },
        "languages": {
          "type": "array",
          "description": "Unique languages available across all decks",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z]{2}$"
          },
          "examples": [
            ["fr", "en"],
            ["fr"]
          ]
        },
        "themes": {
          "type": "array",
          "description": "Unique themes used across all decks",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "examples": [
            ["simplon", "default"],
            ["simplon", "seriph", "academic"]
          ]
        },
        "tags": {
          "type": "array",
          "description": "All unique tags across all decks (sorted alphabetically)",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "examples": [
            ["advanced", "beginner", "database", "queries", "sql"]
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "generated": "2025-11-24T10:30:00Z",
      "version": "1.0.0",
      "decks": [
        {
          "id": "sql-basics",
          "title": "SQL Fundamentals",
          "description": "Introduction to SQL queries and database basics.",
          "status": "published",
          "objectives": ["Write SELECT queries", "Understand JOINs"],
          "prerequisites": ["Basic programming"],
          "duration": "2 hours",
          "theme": "simplon",
          "thumbnail": "./assets/preview.png",
          "tags": ["sql", "beginner"],
          "language": "fr",
          "version": "1.0.0",
          "authors": [{"name": "Training Team"}],
          "created": "2025-11-24",
          "updated": "2025-11-24"
        }
      ],
      "stats": {
        "totalDecks": 1,
        "totalDuration": 120,
        "languages": ["fr"],
        "themes": ["simplon"],
        "tags": ["beginner", "sql"]
      }
    }
  ]
}
