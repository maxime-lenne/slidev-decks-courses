# Multi-Deck Slidev Configuration

# Base URL for deployment (include leading and trailing slashes)
# Examples:
#   - GitHub Pages (repo): BASE_URL=/slidev-simplon-sql-1st-day/
#   - GitHub Pages (user): BASE_URL=/
#   - Custom domain: BASE_URL=/
#   - Local dev: BASE_URL=/
BASE_URL=/

# Build output directory
OUTPUT_DIR=dist

# Development server port
DEV_PORT=5173

# Deck pattern for builds (glob pattern)
DECK_PATTERN=decks/*/slides.md
